# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tableorder

# Security
SECRET_KEY=your-secret-key-change-in-production

# JWT
JWT_EXPIRY_HOURS=16

# AWS
AWS_S3_BUCKET=table-order-images
AWS_REGION=ap-northeast-2

# DB Pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=40

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Logging
LOG_LEVEL=INFO

# Popular Menu
POPULAR_MENU_CACHE_TTL=300
POPULAR_MENU_TOP_PERCENT=20
POPULAR_MENU_DAYS=30

# Login Security
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
