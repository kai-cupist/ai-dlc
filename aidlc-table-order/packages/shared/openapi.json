{
  "openapi": "3.0.3",
  "info": {
    "title": "테이블오더 API",
    "version": "0.1.0",
    "description": "테이블오더 서비스 REST API"
  },
  "servers": [
    { "url": "/api", "description": "API 서버" }
  ],
  "paths": {
    "/auth/admin/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "관리자 로그인",
        "operationId": "adminLogin",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AdminLoginRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "로그인 성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponseWrapped" } } } },
          "401": { "description": "인증 실패", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "429": { "description": "요청 제한 초과" }
        }
      }
    },
    "/auth/table/setup": {
      "post": {
        "tags": ["Auth"],
        "summary": "테이블 초기 설정",
        "operationId": "tableSetup",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TableSetupRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "설정 성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponseWrapped" } } } },
          "400": { "description": "잘못된 요청" }
        }
      }
    },
    "/auth/table/auto-login": {
      "post": {
        "tags": ["Auth"],
        "summary": "테이블 자동 로그인",
        "operationId": "tableAutoLogin",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TableAutoLoginRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "로그인 성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponseWrapped" } } } },
          "401": { "description": "인증 실패" }
        }
      }
    },
    "/auth/token/refresh": {
      "post": {
        "tags": ["Auth"],
        "summary": "토큰 갱신",
        "operationId": "refreshToken",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TokenRefreshRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "갱신 성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponseWrapped" } } } },
          "401": { "description": "유효하지 않은 토큰" }
        }
      }
    },
    "/stores/{storeId}": {
      "get": {
        "tags": ["Store"],
        "summary": "매장 정보 조회",
        "operationId": "getStore",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "매장 정보", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StoreWrapped" } } } }
        }
      }
    },
    "/tables": {
      "get": {
        "tags": ["Table"],
        "summary": "매장 테이블 목록",
        "operationId": "getTables",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "테이블 목록", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TablesWrapped" } } } }
        }
      }
    },
    "/tables/{tableId}/complete": {
      "post": {
        "tags": ["Table"],
        "summary": "테이블 이용 완료",
        "operationId": "completeTable",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "tableId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "이용 완료 처리됨" },
          "404": { "description": "테이블 없음" }
        }
      }
    },
    "/tables/{tableId}/history": {
      "get": {
        "tags": ["Table"],
        "summary": "과거 주문 내역 조회",
        "operationId": "getTableHistory",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "tableId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "date_from", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "date_to", "in": "query", "schema": { "type": "string", "format": "date" } }
        ],
        "responses": {
          "200": { "description": "과거 주문 내역" }
        }
      }
    },
    "/menus": {
      "get": {
        "tags": ["Menu"],
        "summary": "메뉴 목록 조회 (카테고리별)",
        "operationId": "getMenus",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "category_id", "in": "query", "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "카테고리별 메뉴 목록" }
        }
      },
      "post": {
        "tags": ["Menu"],
        "summary": "메뉴 등록",
        "operationId": "createMenu",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateMenuRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "메뉴 등록됨" },
          "422": { "description": "검증 실패" }
        }
      }
    },
    "/menus/{menuId}": {
      "get": {
        "tags": ["Menu"],
        "summary": "메뉴 상세 조회 (옵션 포함)",
        "operationId": "getMenuDetail",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "menuId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "메뉴 상세 + 옵션 그룹" },
          "404": { "description": "메뉴 없음" }
        }
      },
      "put": {
        "tags": ["Menu"],
        "summary": "메뉴 수정",
        "operationId": "updateMenu",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "menuId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateMenuRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "메뉴 수정됨" }
        }
      },
      "delete": {
        "tags": ["Menu"],
        "summary": "메뉴 삭제",
        "operationId": "deleteMenu",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "menuId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "204": { "description": "삭제됨" }
        }
      }
    },
    "/menus/order": {
      "put": {
        "tags": ["Menu"],
        "summary": "메뉴 노출 순서 변경",
        "operationId": "reorderMenus",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ReorderMenusRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "순서 변경됨" }
        }
      }
    },
    "/menus/categories": {
      "get": {
        "tags": ["Menu"],
        "summary": "카테고리 목록",
        "operationId": "getCategories",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "카테고리 목록" }
        }
      }
    },
    "/option-groups": {
      "get": {
        "tags": ["OptionGroup"],
        "summary": "옵션 그룹 목록",
        "operationId": "getOptionGroups",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "옵션 그룹 목록" }
        }
      },
      "post": {
        "tags": ["OptionGroup"],
        "summary": "옵션 그룹 생성",
        "operationId": "createOptionGroup",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateOptionGroupRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "생성됨" }
        }
      }
    },
    "/option-groups/{groupId}": {
      "put": {
        "tags": ["OptionGroup"],
        "summary": "옵션 그룹 수정",
        "operationId": "updateOptionGroup",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "groupId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": { "200": { "description": "수정됨" } }
      },
      "delete": {
        "tags": ["OptionGroup"],
        "summary": "옵션 그룹 삭제",
        "operationId": "deleteOptionGroup",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "groupId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": { "204": { "description": "삭제됨" } }
      }
    },
    "/option-groups/{groupId}/menus/{menuId}": {
      "post": {
        "tags": ["OptionGroup"],
        "summary": "메뉴에 옵션 그룹 연결",
        "operationId": "linkOptionToMenu",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "groupId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "menuId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": { "201": { "description": "연결됨" } }
      },
      "delete": {
        "tags": ["OptionGroup"],
        "summary": "메뉴에서 옵션 그룹 해제",
        "operationId": "unlinkOptionFromMenu",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "groupId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "menuId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": { "204": { "description": "해제됨" } }
      }
    },
    "/orders": {
      "post": {
        "tags": ["Order"],
        "summary": "주문 생성",
        "operationId": "createOrder",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateOrderRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "주문 생성됨" },
          "400": { "description": "검증 실패" }
        }
      },
      "get": {
        "tags": ["Order"],
        "summary": "현재 세션 주문 목록",
        "operationId": "getSessionOrders",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "주문 목록 + total" }
        }
      }
    },
    "/orders/{orderId}/status": {
      "patch": {
        "tags": ["Order"],
        "summary": "주문 상태 변경",
        "operationId": "updateOrderStatus",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "orderId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateOrderStatusRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "상태 변경됨" },
          "400": { "description": "잘못된 상태 전이" }
        }
      }
    },
    "/orders/{orderId}": {
      "delete": {
        "tags": ["Order"],
        "summary": "주문 삭제 (관리자)",
        "operationId": "deleteOrder",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "orderId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "204": { "description": "삭제됨" }
        }
      }
    },
    "/orders/polling": {
      "get": {
        "tags": ["Order"],
        "summary": "폴링 데이터 (관리자 대시보드)",
        "operationId": "getPollingData",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "since", "in": "query", "schema": { "type": "string", "format": "date-time" } }
        ],
        "responses": {
          "200": { "description": "테이블별 주문 현황" }
        }
      }
    },
    "/orders/receipt": {
      "get": {
        "tags": ["Order"],
        "summary": "영수증 조회",
        "operationId": "getReceipt",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "회차별 영수증" }
        }
      }
    },
    "/orders/{orderId}/progress": {
      "get": {
        "tags": ["Order"],
        "summary": "주문 진행 상황",
        "operationId": "getOrderProgress",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "orderId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "진행률 + 예상 시간" }
        }
      }
    },
    "/recommendations": {
      "post": {
        "tags": ["Recommendation"],
        "summary": "추천 메뉴 조회",
        "operationId": "getRecommendations",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RecommendationRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "추천 메뉴 목록" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "AdminLoginRequest": {
        "type": "object",
        "required": ["store_id", "username", "password"],
        "properties": {
          "store_id": { "type": "string", "format": "uuid" },
          "username": { "type": "string", "maxLength": 50 },
          "password": { "type": "string", "minLength": 8 }
        }
      },
      "TableSetupRequest": {
        "type": "object",
        "required": ["store_id", "table_number", "password"],
        "properties": {
          "store_id": { "type": "string", "format": "uuid" },
          "table_number": { "type": "integer", "minimum": 1 },
          "password": { "type": "string", "minLength": 8 }
        }
      },
      "TableAutoLoginRequest": {
        "type": "object",
        "required": ["store_id", "table_number", "password"],
        "properties": {
          "store_id": { "type": "string", "format": "uuid" },
          "table_number": { "type": "integer", "minimum": 1 },
          "password": { "type": "string" }
        }
      },
      "TokenRefreshRequest": {
        "type": "object",
        "required": ["refresh_token"],
        "properties": {
          "refresh_token": { "type": "string" }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "access_token": { "type": "string" },
          "refresh_token": { "type": "string" },
          "token_type": { "type": "string", "enum": ["bearer"] },
          "expires_in": { "type": "integer" }
        }
      },
      "AuthResponseWrapped": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/AuthResponse" }
        }
      },
      "StoreWrapped": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/Store" }
        }
      },
      "Store": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "default_prep_time_minutes": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "TablesWrapped": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Table" } }
        }
      },
      "Table": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "store_id": { "type": "string", "format": "uuid" },
          "table_number": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "CreateMenuRequest": {
        "type": "object",
        "required": ["category_id", "name", "price"],
        "properties": {
          "category_id": { "type": "string", "format": "uuid" },
          "name": { "type": "string", "minLength": 1, "maxLength": 100 },
          "price": { "type": "integer", "minimum": 0 },
          "description": { "type": "string" },
          "image_url": { "type": "string", "format": "uri" }
        }
      },
      "UpdateMenuRequest": {
        "type": "object",
        "properties": {
          "category_id": { "type": "string", "format": "uuid" },
          "name": { "type": "string", "minLength": 1, "maxLength": 100 },
          "price": { "type": "integer", "minimum": 0 },
          "description": { "type": "string" },
          "image_url": { "type": "string" },
          "is_popular": { "type": "boolean" },
          "is_available": { "type": "boolean" }
        }
      },
      "ReorderMenusRequest": {
        "type": "object",
        "required": ["menu_ids"],
        "properties": {
          "menu_ids": { "type": "array", "items": { "type": "string", "format": "uuid" } }
        }
      },
      "CreateOptionGroupRequest": {
        "type": "object",
        "required": ["name", "is_required", "items"],
        "properties": {
          "name": { "type": "string", "maxLength": 50 },
          "is_required": { "type": "boolean" },
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/CreateOptionItemRequest" } }
        }
      },
      "CreateOptionItemRequest": {
        "type": "object",
        "required": ["name", "extra_price"],
        "properties": {
          "name": { "type": "string", "maxLength": 50 },
          "extra_price": { "type": "integer", "minimum": 0 },
          "sort_order": { "type": "integer" }
        }
      },
      "UpdateOptionGroupRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "is_required": { "type": "boolean" },
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/CreateOptionItemRequest" } }
        }
      },
      "CreateOrderRequest": {
        "type": "object",
        "required": ["items"],
        "properties": {
          "items": { "type": "array", "minItems": 1, "items": { "$ref": "#/components/schemas/OrderItemRequest" } }
        }
      },
      "OrderItemRequest": {
        "type": "object",
        "required": ["menu_id", "quantity"],
        "properties": {
          "menu_id": { "type": "string", "format": "uuid" },
          "quantity": { "type": "integer", "minimum": 1 },
          "options": { "type": "array", "items": { "$ref": "#/components/schemas/OrderItemOptionRequest" } }
        }
      },
      "OrderItemOptionRequest": {
        "type": "object",
        "required": ["option_item_id"],
        "properties": {
          "option_item_id": { "type": "string", "format": "uuid" }
        }
      },
      "UpdateOrderStatusRequest": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": { "type": "string", "enum": ["pending", "preparing", "completed"] }
        }
      },
      "RecommendationRequest": {
        "type": "object",
        "required": ["menu_ids"],
        "properties": {
          "menu_ids": { "type": "array", "items": { "type": "string", "format": "uuid" } }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "detail": { "type": "string" },
          "field_errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": { "type": "string" },
                "message": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
